{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "steps": {
    "install": {
      "inputs": [
        {
          "local": true,
          "include": [
            "."
          ]
        }
      ],
      "commands": [
        "cd examples/backend-node && npm ci"
      ]
    }
  },
  "deploy": {
    "startCommand": "cd examples/backend-node && npm start"
  }
}
